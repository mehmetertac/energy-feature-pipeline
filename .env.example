# Environment variables (examples — copy to `.env` locally; do not commit secrets)

# Optional: cached OPSD parquet or CSV path for generation columns
# ENERGY_FP_OPSD_PATH=data/raw/opsd_time_series_60min.parquet

# Optional: hourly load parquet from energy-ts-fundamentals (ENTSO-E export)
# ENERGY_TS_LOAD_PARQUET=../energy-ts-fundamentals/data/raw/de_lu_load_hourly.parquet

# CDS credentials live in ~/.cdsapirc (see Copernicus CDS docs), not here.
